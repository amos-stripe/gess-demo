{{#> base }}

{{#*inline "content-block"}}

<!-- Page header -->
<div style="background: #fff; border-bottom: 1px solid #e5e7eb; padding: 1.375rem 0;">
  <div class="page-content">
    <h1 style="font-size: 1.375rem; font-weight: 700; color: #111827; margin: 0 0 0.2rem;">Payment Confirmation</h1>
    <p style="font-size: 0.875rem; color: #6b7280; margin: 0;">Your payment has been successfully processed</p>
  </div>
</div>

<!-- Content -->
<div class="page-content" style="padding-top: 2rem; padding-bottom: 2rem;">
  <div style="max-width: 540px; margin: 0 auto;">

    <!-- Success card -->
    <div style="background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); border: 1px solid #e5e7eb; padding: 2rem;">

      <!-- Success icon -->
      <div style="width: 3.5rem; height: 3.5rem; background-color: #ecfdf5; border-radius: 9999px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
        <svg fill="none" viewBox="0 0 24 24" stroke="#059669" stroke-width="2.5" style="width: 1.75rem; height: 1.75rem;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h2 style="text-align: center; font-size: 1.375rem; font-weight: 700; color: #111827; margin: 0 0 0.375rem;">Payment Confirmed</h2>
      <p style="text-align: center; font-size: 0.875rem; color: #6b7280; margin: 0 0 1.75rem; line-height: 1.5;">School fees for Term 2, 2026 have been received.<br>A receipt has been sent to your email address.</p>

      <!-- Receipt details -->
      <div style="border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
        <div style="background: #f9fafb; padding: 0.75rem 1.25rem; font-size: 0.7rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.06em;">
          Receipt Details
        </div>
        <div style="padding: 0 1.25rem;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.75rem 0; border-bottom: 1px solid #f3f4f6;">
            <span style="color: #6b7280; font-size: 0.875rem;">Amount Paid</span>
            <span style="color: #111827; font-weight: 700; font-size: 1rem;">SGD {{amount}}</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.75rem 0; border-bottom: 1px solid #f3f4f6;">
            <span style="color: #6b7280; font-size: 0.875rem;">Date</span>
            <span style="color: #111827; font-weight: 500; font-size: 0.875rem;">{{date}}</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.75rem 0; border-bottom: 1px solid #f3f4f6;">
            <span style="color: #6b7280; font-size: 0.875rem;">Family</span>
            <span style="color: #111827; font-weight: 500; font-size: 0.875rem;">Smith Family</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.75rem 0; border-bottom: 1px solid #f3f4f6;">
            <span style="color: #6b7280; font-size: 0.875rem;">Term</span>
            <span style="color: #111827; font-weight: 500; font-size: 0.875rem;">Term 2, 2026</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.75rem 0; border-bottom: 1px solid #f3f4f6;">
            <span style="color: #6b7280; font-size: 0.875rem;">Reference</span>
            <span style="color: #111827; font-weight: 500; font-size: 0.75rem; font-family: 'SF Mono', 'Fira Code', monospace;">{{reference}}</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.75rem 0;">
            <span style="color: #6b7280; font-size: 0.875rem;">Status</span>
            <span style="color: #059669; font-weight: 600; font-size: 0.875rem;">Paid</span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
        <a href="/fees" style="flex: 1; display: block; padding: 0.75rem; text-align: center; background-color: #084e29; color: #fff; border-radius: 8px; font-size: 0.9rem; font-weight: 600; text-decoration: none;">
          Back to Portal
        </a>
        {{#if receipt_url}}
        <a href="{{receipt_url}}" target="_blank" rel="noopener" style="flex: 1; display: block; padding: 0.75rem; text-align: center; background-color: #f3f4f6; color: #374151; border-radius: 8px; font-size: 0.9rem; font-weight: 600; text-decoration: none; border: 1px solid #e5e7eb;">
          Download Receipt
        </a>
        {{/if}}
      </div>

      <!-- Reset link -->
      <div style="text-align: center; margin-top: 1.25rem;">
        <a href="/reset" style="font-size: 0.75rem; color: #9ca3af; text-decoration: none;">Reset Demo</a>
      </div>

    </div>
  </div>
</div>

{{/inline}}
{{/base}}
